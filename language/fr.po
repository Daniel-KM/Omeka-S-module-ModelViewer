msgstr "Lecteur 3D : Propriété du média pour la configuration spécifique"

#: src/Form/SettingsFieldset.php:33
msgid "It is recommended to hide it on public display."
msgstr "Il est recommandé de cacher cette valeur dans l’affichage public."

#: src/Form/SettingsFieldset.php:49
msgid "Model Viewer: Default scene config (json)"
msgstr "Lecteur 3D : Config de la scène par défaut (json)"

#: src/Form/SettingsFieldset.php:64
msgid "Model Viewer: Load all ThreeJS addons"
msgstr "Lecteur 3D : Chargement de tous les modules ThreeJs"

