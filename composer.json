{
    "name": "daniel-km/omeka-s-module-modelviewer",
    "type": "omeka-s-module",
    "description": "Module for Omeka S: Integrates the Three js viewer in order to display 3D models.",
    "keywords": [
        "Omeka S",
        "Omeka S module",
        "digital library",
        "model viewer",
        "3D viewer",
        "viewer",
        "threejs",
        "gltf",
        "glb",
        "dae",
        "fbx"
    ],
    "license": "CECILL-2.1",
    "homepage": "https://gitlab.com/Daniel-KM/Omeka-S-module-ModelViewer",
    "authors": [
        {
            "name": "Daniel Berthereau",
            "email": "Daniel.packagist@Berthereau.net"
        }
    ],
    "support": {
        "issues": "https://gitlab.com/Daniel-KM/Omeka-S-module-ModelViewer/-/issues",
        "forum": "https://forum.omeka.org/"
    },
    "_require (not set until Omeka S merges PR #2412)": {
        "omeka/omeka-s": "^4.0",
        "daniel-km/omeka-s-module-common": "*"
    },
    "require": {
        "sempia/external-assets": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "ModelViewer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ModelViewerTest\\": "tests/ModelViewerTest/"
        }
    },
    "config": {
        "allow-plugins": {
            "sempia/external-assets": true
        }
    },
    "extra": {
        "installer-name": "ModelViewer",
        "external-assets": {
            "asset/vendor/threejs/": "https://github.com/Daniel-KM/Omeka-S-module-ModelViewer/releases/download/3.4.2-174/threejs-174.tar.gz",
            "asset/vendor/gsap/gsap.min.js": "https://raw.githubusercontent.com/greensock/GSAP/master/dist/gsap.min.js",
            "asset/vendor/matcaps/": "https://github.com/nidorx/matcaps/releases/download/v1.0/64.zip"
        }
    }
}
